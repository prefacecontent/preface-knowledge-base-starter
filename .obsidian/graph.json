{
  "collapse-filter": true,
  "search": "path:wiki/",
  "showTags": false,
  "showAttachments": false,
  "hideUnresolved": true,
  "showOrphans": false,
  "collapse-color-groups": false,
  "colorGroups": [
    { "query": "path:wiki/entities",  "color": { "a": 1, "rgb": 8174056 } },
    { "query": "path:wiki/concepts",  "color": { "a": 1, "rgb": 4552349 } },
    { "query": "path:wiki/sources",   "color": { "a": 1, "rgb": 8947848 } },
    { "query": "path:wiki/synthesis", "color": { "a": 1, "rgb": 15716514 } },
    { "query": "path:wiki/context",   "color": { "a": 1, "rgb": 12439266 } }
  ],
  "collapse-display": false,
  "showArrow": true,
  "textFadeMultiplier": 0,
  "nodeSizeMultiplier": 1,
  "lineSizeMultiplier": 1,
  "collapse-forces": false,
  "centerStrength": 0.52,
  "repelStrength": 10,
  "linkStrength": 1,
  "linkDistance": 250,
  "scale": 1,
  "close": false
